# Copy this file to terraform.tfvars and fill in your values.
# DO NOT commit terraform.tfvars to version control.

project_id     = "your-gcp-project-id"
region         = "us-central1"
zone           = "us-central1-a"
ssh_public_key = "ssh-rsa AAAA...your-public-key-here... you@host"
ssh_user       = "ubuntu"

# Machine types — keep defaults for free-tier / low-cost.
# inference-vm needs ≥4 GB RAM for the model; e2-medium (4 GB) is the minimum.
# api_machine_type       = "e2-small"
# caller_machine_type    = "e2-small"
# inference_machine_type = "e2-medium"
